@model QuantumFlow.Models.DashboardViewModel

@{
    ViewData["Title"] = "QuantumFlow Dashboard";
    Layout = "_Layout";  @* Your shared layout with navbar/sidebar *@
}

@section Styles {
    <style>
        .dashboard-card { border-radius: 12px; box-shadow: 0 4px 15px rgba(0,0,0,0.08); }
        .chart-container { position: relative; height: 380px; }
    </style>
}

<div class="container-fluid py-4">
    <!-- Header -->
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1 class="h3 fw-bold text-dark">Corporate Expense & Revenue Dashboard</h1>
        <div class="d-flex gap-3">
            <div class="input-group" style="width: 368px;">
                <span class="input-group-text">From</span>
                <input type="date" id="dateFrom" class="form-control" value="2025-01-01">
                <span class="input-group-text">To</span>
                <input type="date" id="dateTo" class="form-control" value="2025-03-31">
            </div>
            <select id="departmentFilter" class="form-select w-auto">
                <option value="">All Departments</option>
                <option value="Marketing">Marketing</option>
                <option value="Sales">Sales</option>
                <option value="IT">IT</option>
                <option value="HR">HR</option>
                <option value="Operations">Operations</option>
            </select>
            <button onclick="refreshDashboard()" class="btn btn-primary">Refresh</button>
        </div>
    </div>

    <!-- KPI Cards -->
    <div class="row g-3 mb-5">
        <div class="col-xl-3 col-md-6">
            <div class="dashboard-card bg-white p-4">
                <div class="d-flex justify-content-between">
                    <div>
                        <p class="text-muted mb-1">Total Revenue (YTD)</p>
                        <h3 class="fw-bold text-success" id="kpiRevenue">$1,245,800</h3>
                    </div>
                    <i class="bi bi-graph-up-arrow fs-1 text-success"></i>
                </div>
                <small class="text-success">↑ 12% from last quarter</small>
            </div>
        </div>
        <div class="col-xl-3 col-md-6">
            <div class="dashboard-card bg-white p-4">
                <div class="d-flex justify-content-between">
                    <div>
                        <p class="text-muted mb-1">Total Expenses (YTD)</p>
                        <h3 class="fw-bold text-danger" id="kpiExpenses">$892,450</h3>
                    </div>
                    <i class="bi bi-graph-down-arrow fs-1 text-danger"></i>
                </div>
                <small class="text-danger">↓ 4% from last quarter</small>
            </div>
        </div>
        <div class="col-xl-3 col-md-6">
            <div class="dashboard-card bg-white p-4">
                <div class="d-flex justify-content-between">
                    <div>
                        <p class="text-muted mb-1">Net Profit</p>
                        <h3 class="fw-bold text-primary" id="kpiProfit">$353,350</h3>
                    </div>
                    <i class="bi bi-currency-exchange fs-1 text-primary"></i>
                </div>
                <small class="text-primary">18% margin</small>
            </div>
        </div>
        <div class="col-xl-3 col-md-6">
            <div class="dashboard-card bg-white p-4">
                <div class="d-flex justify-content-between">
                    <div>
                        <p class="text-muted mb-1">Cash Flow (YTD)</p>
                        <h3 class="fw-bold" id="kpiCashFlow">$421,200</h3>
                    </div>
                    <i class="bi bi-cash-stack fs-1 text-info"></i>
                </div>
                <small class="text-info">Healthy liquidity</small>
            </div>
        </div>
    </div>

    <div class="row g-4">
        <!-- Expenses by Department -->
        <div class="col-xl-8">
            <div class="dashboard-card bg-white p-4">
                <h5 class="fw-semibold mb-3">Expenses by Department</h5>
                <div class="chart-container">
                    <canvas id="expensesByDeptChart"></canvas>
                </div>
            </div>
        </div>

        <!-- Revenue Breakdown -->
        <div class="col-xl-4">
            <div class="dashboard-card bg-white p-4">
                <h5 class="fw-semibold mb-3">Revenue by Category</h5>
                <div class="chart-container">
                    <canvas id="revenueBreakdownChart"></canvas>
                </div>
            </div>
        </div>

        <!-- Cash Flow Trend -->
        <div class="col-xl-8">
            <div class="dashboard-card bg-white p-4">
                <h5 class="fw-semibold mb-3">Cash Flow Trend (Last 6 Months)</h5>
                <div class="chart-container">
                    <canvas id="cashFlowChart"></canvas>
                </div>
            </div>
        </div>

        <!-- Budget vs Actual -->
        <div class="col-xl-4">
            <div class="dashboard-card bg-white p-4">
                <h5 class="fw-semibold mb-3">Budget vs Actual (Q1 2025)</h5>
                <div class="chart-container">
                    <canvas id="budgetVsActualChart"></canvas>
                </div>
            </div>
        </div>

        <!-- Top Expense Categories -->
        <div class="col-xl-12">
            <div class="dashboard-card bg-white p-4">
                <h5 class="fw-semibold mb-3">Top 5 Expense Categories</h5>
                <div class="chart-container" style="height: 300px;">
                    <canvas id="topCategoriesChart"></canvas>
                </div>
            </div>
        </div>

        <!-- Recent Transactions Table -->
        <div class="col-xl-12">
            <div class="dashboard-card bg-white p-4">
                <h5 class="fw-semibold mb-3">Recent Transactions</h5>
                <table class="table table-hover align-middle" id="transactionsTable">
                    <thead class="table-light">
                        <tr>
                            <th>Date</th>
                            <th>Description</th>
                            <th>Department</th>
                            <th>Category</th>
                            <th class="text-end">Amount</th>
                            <th>Status</th>
                        </tr>
                    </thead>
                    <tbody>
                        <!-- Populated via JavaScript from sample data -->
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.1/dist/chart.umd.min.js"></script>
    <script>
        // Sample data – mirrors your DB schema (Transactions + Departments + BudgetItems)
        const sampleData = {
            departments: ["Marketing", "Sales", "IT", "HR", "Operations"],
            expensesByDept: [12450, 87500, 3200, 8900, 15400],
            revenueCategories: ["Software Licenses", "Consulting", "Product Sales", "Services"],
            revenueValues: [420000, 315000, 280000, 230800],
            cashFlowMonths: ["Oct", "Nov", "Dec", "Jan", "Feb", "Mar"],
            cashFlowValues: [89000, 112000, 95000, 134000, 98000, 145000],
            budgetLabels: ["Marketing", "Sales", "IT"],
            budgetAmounts: [15000, 90000, 25000],
            actualAmounts: [12450, 87500, 3200],
            topCategories: ["Salaries", "Marketing Campaigns", "Software", "Utilities", "Travel"],
            topCategoryValues: [245000, 98000, 67000, 42000, 31000],
            transactions: [
                { date: "2025-03-25", desc: "Office Utilities – March", dept: "Operations", cat: "Facilities", amount: 3200.75, status: "Reconciled" },
                { date: "2025-03-20", desc: "Enterprise Software License", dept: "IT", cat: "Revenue", amount: -87500, status: "Posted" },
                { date: "2025-03-15", desc: "Q1 Marketing Campaign", dept: "Marketing", cat: "Advertising", amount: 12450, status: "Posted" }
            ]
        };

        function renderCharts() {
            // 1. Expenses by Department (Bar)
            new Chart(document.getElementById('expensesByDeptChart'), {
                type: 'bar',
                data: {
                    labels: sampleData.departments,
                    datasets: [{
                        label: 'Expenses ($)',
                        data: sampleData.expensesByDept,
                        backgroundColor: '#e63939',
                        borderColor: '#e63939',
                        borderWidth: 1
                    }]
                },
                options: { responsive: true, maintainAspectRatio: false, plugins: { legend: { display: false } } }
            });

            // 2. Revenue Breakdown (Doughnut)
            new Chart(document.getElementById('revenueBreakdownChart'), {
                type: 'doughnut',
                data: {
                    labels: sampleData.revenueCategories,
                    datasets: [{
                        data: sampleData.revenueValues,
                        backgroundColor: ['#2a9d8f', '#e76f51', '#f4a261', '#264653']
                    }]
                },
                options: { responsive: true, maintainAspectRatio: false }
            });

            // 3. Cash Flow Trend (Line)
            new Chart(document.getElementById('cashFlowChart'), {
                type: 'line',
                data: {
                    labels: sampleData.cashFlowMonths,
                    datasets: [{
                        label: 'Net Cash Flow',
                        data: sampleData.cashFlowValues,
                        borderColor: '#1d3557',
                        tension: 0.3,
                        fill: false
                    }]
                },
                options: { responsive: true, maintainAspectRatio: false }
            });

            // 4. Budget vs Actual (Grouped Bar)
            new Chart(document.getElementById('budgetVsActualChart'), {
                type: 'bar',
                data: {
                    labels: sampleData.budgetLabels,
                    datasets: [
                        { label: 'Budget', data: sampleData.budgetAmounts, backgroundColor: '#457b9d' },
                        { label: 'Actual', data: sampleData.actualAmounts, backgroundColor: '#e63939' }
                    ]
                },
                options: { responsive: true, maintainAspectRatio: false, scales: { y: { beginAtZero: true } } }
            });

            // 5. Top Expense Categories (Horizontal Bar)
            new Chart(document.getElementById('topCategoriesChart'), {
                type: 'bar',
                data: {
                    labels: sampleData.topCategories,
                    datasets: [{
                        label: 'Amount ($)',
                        data: sampleData.topCategoryValues,
                        backgroundColor: '#f77f00',
                        borderColor: '#f77f00',
                        borderWidth: 1
                    }]
                },
                options: { indexAxis: 'y', responsive: true, maintainAspectRatio: false }
            });

            // Populate Recent Transactions Table
            const tbody = document.querySelector('#transactionsTable tbody');
            tbody.innerHTML = sampleData.transactions.map(t => `
                <tr>
                    <td>${t.date}</td>
                    <td>${t.desc}</td>
                    <td>${t.dept}</td>
                    <td>${t.cat}</td>
                    <td class="text-end ${t.amount < 0 ? 'text-success' : 'text-danger'}">$${Math.abs(t.amount).toLocaleString()}</td>
                    <td><span class="badge bg-secondary">${t.status}</span></td>
                </tr>
            `).join('');
        }

        function refreshDashboard() {
            // In production: fetch from your C# API endpoints
            // e.g. fetch('/api/reports/expenses-by-dept').then(...).then(renderCharts)
            renderCharts(); // Demo refresh
            alert('Dashboard refreshed with live API data (demo mode)');
        }

        // Initial render
        window.onload = renderCharts;
    </script>
}