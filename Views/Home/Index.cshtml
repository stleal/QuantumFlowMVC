@{
    ViewData["Title"] = "Sign In";
}

<section class="login-shell">
    <div class="row g-4 align-items-stretch">
        <div class="col-lg-6">
            <section class="login-panel login-panel--brand h-100">
                <p class="login-panel__eyebrow">Internal Finance Operations</p>
                <h1 class="login-panel__title">Access QuantumFlow</h1>
                <p class="login-panel__copy">
                    Continue into the revenue and expense workspace used by finance, operations, and department leadership.
                    The same reporting environment is available after authentication, with the current review cycle ready on entry.
                </p>

                <div class="login-highlights">
                    <article class="login-highlight">
                        <span class="login-highlight__value">12</span>
                        <span class="login-highlight__label">Department views available after sign-in</span>
                    </article>
                    <article class="login-highlight">
                        <span class="login-highlight__value">24h</span>
                        <span class="login-highlight__label">Target variance response window</span>
                    </article>
                </div>

                <div class="login-support">
                    <p class="login-support__title">Need access?</p>
                    <p class="login-support__copy">Contact your QuantumFlow administrator if you need credentials or account recovery support.</p>
                </div>
            </section>
        </div>

        <div class="col-lg-6">
            <section class="login-panel login-panel--form h-100">
                <div class="login-panel__header">
                    <p class="login-panel__eyebrow">Welcome Back</p>
                    <h2 class="login-form__title">Sign in to continue</h2>
                    <p class="login-form__subtitle">Enter your internal account details to open the dashboard.</p>
                </div>

                <form class="login-form" asp-controller="Dashboard" asp-action="Index" method="get">
                    <div class="login-form__field">
                        <label class="login-form__label" for="work-email">Work email</label>
                        <input class="form-control login-form__input" id="work-email" name="email" type="email" placeholder="name@quantumflow.local" autocomplete="email" />
                    </div>

                    <div class="login-form__field">
                        <div class="login-form__label-row">
                            <label class="login-form__label" for="password">Password</label>
                            <a class="login-form__link" asp-controller="Home" asp-action="Privacy">Forgot password?</a>
                        </div>
                        <input class="form-control login-form__input" id="password" name="password" type="password" placeholder="Enter your password" autocomplete="current-password" />
                    </div>

                    <div class="login-form__row">
                        <div class="form-check login-form__check">
                            <input class="form-check-input" type="checkbox" value="true" id="remember-me" name="rememberMe" />
                            <label class="form-check-label" for="remember-me">Keep me signed in on this device</label>
                        </div>
                        <span class="login-form__meta">Protected internal access</span>
                    </div>

                    <button class="btn home-btn home-btn--primary login-form__submit" type="submit">Sign In</button>
                </form>

                <div class="login-note">
                    <p class="login-note__title">Secure session routing</p>
                    <p class="login-note__copy">After sign-in, you will be taken directly into the operating dashboard for current revenue and expense review.</p>
                </div>
            </section>
        </div>
    </div>
</section>
