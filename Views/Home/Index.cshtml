@{
    ViewData["Title"] = "Home";
}

<section class="home-hero">
    <div class="row g-4 align-items-stretch">
        <div class="col-xl-7">
            <article class="home-hero__panel h-100">
                <p class="home-eyebrow">Operations Overview</p>
                <h1 class="home-title">One place to review performance, exceptions, and next actions.</h1>
                <p class="home-copy mb-0">
                    QuantumFlow gives finance and operations teams a shared operating view for revenue, expenses, and follow-up work.
                    Use it to move from reporting into action without bouncing between disconnected spreadsheets, dashboards, and message threads.
                </p>

                <div class="home-actions">
                    <a class="btn home-btn home-btn--primary" asp-controller="Dashboard" asp-action="Index">Open Dashboard</a>
                    <a class="btn home-btn home-btn--secondary" asp-controller="Prompt" asp-action="Index">Go To Prompt Workspace</a>
                </div>
            </article>
        </div>
        <div class="col-xl-5">
            <article class="home-hero__panel home-hero__panel--accent h-100">
                <p class="home-panel-label">Why Teams Use It</p>

                <div class="home-metric-grid">
                    <article class="home-metric-card">
                        <span class="home-metric-value">1</span>
                        <span class="home-metric-label">Shared workspace for current financial signals and operational context</span>
                    </article>
                    <article class="home-metric-card">
                        <span class="home-metric-value">3</span>
                        <span class="home-metric-label">Core workflows: monitor, investigate, and prepare follow-up actions</span>
                    </article>
                    <article class="home-metric-card">
                        <span class="home-metric-value">24h</span>
                        <span class="home-metric-label">Target response window for material variances and unresolved questions</span>
                    </article>
                    <article class="home-metric-card">
                        <span class="home-metric-value">100%</span>
                        <span class="home-metric-label">Focused on keeping reporting and decision support in one internal app</span>
                    </article>
                </div>

                <div class="home-callout">
                    <h2 class="home-callout__title h5">Signed in as @User.Identity?.Name</h2>
                    <p class="home-callout__text mb-0">
                        Start here when you need context on what the platform is for, then branch into the dashboard for metrics or the prompt page for guided analysis.
                    </p>
                </div>
            </article>
        </div>
    </div>
</section>

<section class="home-section">
    <div class="row g-4">
        <div class="col-lg-4">
            <article class="home-card h-100">
                <p class="home-card__eyebrow">Purpose</p>
                <h2 class="home-card__title">What QuantumFlow is for</h2>
                <p class="home-card__copy mb-0">
                    The app is built to help teams understand financial performance quickly, isolate meaningful changes, and keep internal review work moving.
                </p>
            </article>
        </div>
        <div class="col-lg-4">
            <article class="home-card h-100">
                <p class="home-card__eyebrow">Inside The App</p>
                <h2 class="home-card__title">What you can do here</h2>
                <ul class="home-checklist">
                    <li>Review current revenue and expense reporting in the dashboard.</li>
                    <li>Use the prompt workspace to turn questions into structured analysis.</li>
                    <li>Keep a common view across finance, operations, and leadership discussions.</li>
                </ul>
            </article>
        </div>
        <div class="col-lg-4">
            <article class="home-card h-100">
                <p class="home-card__eyebrow">Best Use</p>
                <h2 class="home-card__title">When to start here</h2>
                <p class="home-card__copy mb-0">
                    Use this page as the signed-in landing area when you want orientation before jumping into a specific tool or when you need a concise explanation of the app for another user.
                </p>
            </article>
        </div>
    </div>
</section>

<section class="home-section">
    <article class="home-card">
        <p class="home-card__eyebrow">Workflow</p>
        <h2 class="home-card__title">A simple operating rhythm</h2>

        <div class="home-process">
            <div class="home-process__item">
                <span class="home-process__step">1</span>
                <div>
                    <h3 class="h5 mb-2">Start with the signal</h3>
                    <p class="mb-0">Open the dashboard to review performance, spot outliers, and frame the issue that needs attention.</p>
                </div>
            </div>
            <div class="home-process__item">
                <span class="home-process__step">2</span>
                <div>
                    <h3 class="h5 mb-2">Investigate with context</h3>
                    <p class="mb-0">Move into the prompt workspace when a metric needs explanation, comparison, or deeper narrative support.</p>
                </div>
            </div>
            <div class="home-process__item">
                <span class="home-process__step">3</span>
                <div>
                    <h3 class="h5 mb-2">Turn review into action</h3>
                    <p class="mb-0">Use the output to support finance reviews, leadership updates, and next-step decisions with less friction.</p>
                </div>
            </div>
        </div>
    </article>
</section>